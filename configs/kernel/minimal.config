# Minimal kernel configuration for PPPwn_live
CONFIG_X86_64=y
CONFIG_64BIT=y
CONFIG_SMP=y
CONFIG_PREEMPT=y

# Basic setup
CONFIG_LOCALVERSION="-pppwn"
CONFIG_DEFAULT_HOSTNAME="pppwn"
CONFIG_SWAP=n
CONFIG_SYSVIPC=n
CONFIG_IKCONFIG=y
CONFIG_IKCONFIG_PROC=y

# Init RAM filesystem and RAM disk support
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y

# Processor type and features
CONFIG_GENERIC_CPU=y
CONFIG_NR_CPUS=2
CONFIG_PROCESSOR_SELECT=y

# Bus options
CONFIG_PCI=y
CONFIG_PCI_MSI=y

# Networking support
CONFIG_NET=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_INET=y
CONFIG_IPV6=n
CONFIG_NETFILTER=y
CONFIG_NF_CONNTRACK=y

# Network device support
CONFIG_NETDEVICES=y
CONFIG_ETHERNET=y
CONFIG_NET_VENDOR_INTEL=y
CONFIG_E1000=y
CONFIG_NET_VENDOR_REALTEK=y
CONFIG_8139TOO=y

# PPP support
CONFIG_PPP=y
CONFIG_PPP_ASYNC=y
CONFIG_PPP_DEFLATE=y

# File systems
CONFIG_EXT4_FS=y
CONFIG_TMPFS=y
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_XZ=y

# Executable file formats
CONFIG_BINFMT_ELF=y

# Device Drivers
CONFIG_BLK_DEV=y
CONFIG_BLK_DEV_SD=y
CONFIG_ATA=y
CONFIG_SATA_AHCI=y

# Console
CONFIG_VT=y
CONFIG_VT_CONSOLE=y
CONFIG_VGA_CONSOLE=y

# Security options
CONFIG_SECURITY=y
CONFIG_SECURITY_NETWORK=y

# Crypto API
CONFIG_CRYPTO=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_AES=y 