# Minimal BusyBox configuration for PPPwn_live
CONFIG_STATIC=y
CONFIG_INSTALL_NO_USR=y

# General Configuration
CONFIG_FEATURE_DEVPTS=y
CONFIG_FEATURE_CLEAN_UP=y
CONFIG_FEATURE_SUID=n
CONFIG_FEATURE_SYSLOG=y

# Build Options
CONFIG_CROSS_COMPILER_PREFIX=""
CONFIG_EXTRA_CFLAGS="-Os"
CONFIG_EXTRA_LDFLAGS="-static"

# Applets
CONFIG_INIT=y
CONFIG_FEATURE_INIT_SYSLOG=y

# Essential commands
CONFIG_ASH=y
CONFIG_ASH_BUILTIN_ECHO=y
CONFIG_ASH_BUILTIN_TEST=y
CONFIG_CAT=y
CONFIG_CHMOD=y
CONFIG_CP=y
CONFIG_DMESG=y
CONFIG_ECHO=y
CONFIG_GREP=y
CONFIG_KILL=y
CONFIG_LS=y
CONFIG_MKDIR=y
CONFIG_MKNOD=y
CONFIG_MOUNT=y
CONFIG_MV=y
CONFIG_PS=y
CONFIG_RM=y
CONFIG_SYNC=y
CONFIG_UMOUNT=y

# Networking
CONFIG_FEATURE_IPV6=n
CONFIG_FEATURE_PREFER_IPV4_ADDRESS=y
CONFIG_IFCONFIG=y
CONFIG_FEATURE_IFCONFIG_STATUS=y
CONFIG_IP=y
CONFIG_FEATURE_IP_ADDRESS=y
CONFIG_FEATURE_IP_LINK=y
CONFIG_FEATURE_IP_ROUTE=y
CONFIG_DHCPC=y
CONFIG_UDHCPC=y

# PPP
CONFIG_PPPD=y
CONFIG_FEATURE_PPPD_FILTER=y

# Process Utilities
CONFIG_FREE=y
CONFIG_KILL=y
CONFIG_PS=y

# System Logging
CONFIG_SYSLOGD=y
CONFIG_LOGREAD=y

# Linux System Utilities
CONFIG_MOUNT=y
CONFIG_FEATURE_MOUNT_HELPERS=y 